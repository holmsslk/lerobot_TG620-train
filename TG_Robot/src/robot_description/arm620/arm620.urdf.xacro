      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.0083082 -0.0000009 0.066279" rpy="0 0 0" />
      <mass value="1.0225" />
      <inertia ixx="0.0003347" ixy="0" ixz="-0.000007" iyy="0.0002898" iyz="0" izz="0.0002636" />
    </inertial>
