<?xml version="1.0"?>
<robot name="arm620" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find robot_description)/arm620/meshes/arm620/base_link.STL" />
      </geometry>
      <material name="base_link_mat">
        <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find robot_description)/arm620/meshes/arm620/base_link.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.0000349 0 0.041738" rpy="0 0 0" />
      <mass value="1.235" />
      <inertia ixx="0.000693" ixy="0" ixz="-0.0000008" iyy="0.0006922" iyz="0" izz="0.0005921" />
    </inertial>
  </link>

  <link name="Link1">
