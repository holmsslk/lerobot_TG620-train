<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="arm620">

    <!-- Import arm620 model from xacro (contains world/base fixed joint) -->
    <xacro:include filename="$(find robot_description)/arm620/arm620.urdf.xacro" />

    <!-- Gazebo properties -->
    <gazebo reference="base_link">
        <material>Gazebo/Turquoise</material>
        <self_collide>false</self_collide>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link1">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link2">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link3">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link4">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link5">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="Link6">
        <material>Gazebo/Turquoise</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="gripper_base">
        <material>Gazebo/Black</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_narrow1_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_narrow2_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_narrow3_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_wide1_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_wide2_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_wide3_Link">
        <material>Gazebo/DarkGrey</material>
        <gravity>false</gravity>
    </gazebo>
    <gazebo reference="hand_narrow_loop_Link">
        <material>Gazebo/DarkGrey</material>
        <mu1>1.6</mu1>
        <mu2>1.6</mu2>
        <kp>1000000.0</kp>
        <kd>5.0</kd>
    </gazebo>
    <gazebo reference="hand_wide_loop_Link">
        <material>Gazebo/DarkGrey</material>
        <mu1>1.6</mu1>
        <mu2>1.6</mu2>
        <kp>1000000.0</kp>
        <kd>5.0</kd>
    </gazebo>

    <gazebo>
        <is_static>false</is_static>
        <self_collide>false</self_collide>
    </gazebo>

    <!-- OmniPicker gripper: simplified bilateral linkage for stable grasping -->
    <joint name="gripper_base_joint" type="fixed">
        <origin xyz="0 0 0.022" rpy="0 0 1.5708"/>
        <parent link="Link6"/>
        <child link="gripper_base"/>
    </joint>

    <link name="gripper_base">
        <inertial>
            <origin xyz="-0.00005520 1.2341E-05 0.03296193" rpy="0 0 0"/>
            <mass value="0.25641368"/>
            <inertia ixx="4.6351E-04" ixy="-1.0E-08" ixz="-1.04E-06" iyy="4.4525E-04" iyz="-5.00E-08" izz="1.0438E-04"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/base_link.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/base_link.STL"/>
            </geometry>
        </collision>
    </link>

    <!-- Visual follower links: rigidly attach full OmniPicker geometry to each driven finger -->
    <link name="hand_narrow1_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/narrow1_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_narrow1_joint" type="fixed">
        <origin xyz="-0.01737 -0.002133 -0.000028" rpy="0 0 0"/>
        <parent link="hand_narrow_loop_Link"/>
        <child link="hand_narrow1_Link"/>
    </joint>

    <link name="hand_narrow2_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/narrow2_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_narrow2_joint" type="fixed">
        <origin xyz="0.030852 0.018551 0" rpy="0 0 0"/>
        <parent link="hand_narrow1_Link"/>
        <child link="hand_narrow2_Link"/>
    </joint>

    <link name="hand_narrow3_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/narrow3_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_narrow3_joint" type="fixed">
        <origin xyz="0.018118 -0.01574 0" rpy="0 0 0"/>
        <parent link="hand_narrow2_Link"/>
        <child link="hand_narrow3_Link"/>
    </joint>

    <link name="hand_wide1_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/wide1_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_wide1_joint" type="fixed">
        <origin xyz="-0.01737 0.002133 0.000028" rpy="0 0 0"/>
        <parent link="hand_wide_loop_Link"/>
        <child link="hand_wide1_Link"/>
    </joint>

    <link name="hand_wide2_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/wide2_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_wide2_joint" type="fixed">
        <origin xyz="0.030852 -0.018551 0" rpy="0 0 0"/>
        <parent link="hand_wide1_Link"/>
        <child link="hand_wide2_Link"/>
    </joint>

    <link name="hand_wide3_Link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/wide3_Link.STL"/>
            </geometry>
        </visual>
    </link>

    <joint name="hand_wide3_joint" type="fixed">
        <origin xyz="0.018118 0.01574 0" rpy="0 0 0"/>
        <parent link="hand_wide2_Link"/>
        <child link="hand_wide3_Link"/>
    </joint>

    <link name="hand_narrow_loop_Link">
        <inertial>
            <origin xyz="0.014869 -0.0036066 0.00029307" rpy="0 0 0"/>
            <mass value="0.022591"/>
            <inertia ixx="4.3916E-06" ixy="1.114E-07" ixz="-4.9655E-12" iyy="4.737E-06" iyz="1.7121E-11" izz="6.0445E-07"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/narrow_loop_Link.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0.014 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="0.040 0.010 0.020"/>
            </geometry>
        </collision>
    </link>

    <joint name="hand_narrow_loop_joint" type="revolute">
        <origin xyz="0 -0.021633 0.07387" rpy="-2.9951 -1.5708 -0.15964"/>
        <parent link="gripper_base"/>
        <child link="hand_narrow_loop_Link"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-1.2" upper="1.2" effort="10" velocity="4.0"/>
        <dynamics damping="0.6" friction="0.2"/>
    </joint>

    <link name="hand_wide_loop_Link">
        <inertial>
            <origin xyz="0.016268 0.0040555 0.00030323" rpy="0 0 0"/>
            <mass value="0.025142"/>
            <inertia ixx="5.887E-06" ixy="-1.1234E-07" ixz="2.1954E-11" iyy="6.236E-06" iyz="-9.473E-12" izz="6.2389E-07"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="file://$(find robot_description)/meshes/omnipicker_gripper/wide_loop_Link.STL"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0.014 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="0.040 0.010 0.020"/>
            </geometry>
        </collision>
    </link>

    <joint name="hand_wide_loop_joint" type="revolute">
        <origin xyz="0 0.021633 0.07387" rpy="-2.9951 -1.5708 -0.15964"/>
        <parent link="gripper_base"/>
        <child link="hand_wide_loop_Link"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-1.2" upper="1.2" effort="10" velocity="4.0"/>
        <dynamics damping="0.6" friction="0.2"/>
    </joint>

    <!-- Overview camera 1: front view (see full robot body) -->
    <link name="front_camera_link">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
        <visual>
            <geometry>
                <box size="0.03 0.03 0.03"/>
            </geometry>
            <material name="front_camera_color">
                <color rgba="0.15 0.45 0.85 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.03"/>
            </geometry>
        </collision>
    </link>

    <joint name="front_camera_joint" type="fixed">
        <parent link="world"/>
        <child link="front_camera_link"/>
        <origin xyz="0.90 0.00 0.40" rpy="0 -0.15 3.14159"/>
    </joint>

    <gazebo reference="front_camera_link">
        <gravity>false</gravity>
        <sensor type="camera" name="front_camera_sensor">
            <always_on>true</always_on>
            <update_rate>30.0</update_rate>
            <camera>
                <horizontal_fov>2.00</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>15.0</far>
                </clip>
            </camera>
            <plugin name="front_camera_plugin" filename="libgazebo_ros_camera.so">
                <ros>
                    <namespace>/front_camera</namespace>
                    <remapping>image_raw:=image_raw</remapping>
                </ros>
                <camera_name>front_camera</camera_name>
                <frame_name>front_camera_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Overview camera 2: side-front view (see full robot body) -->
    <link name="side_front_camera_link">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
        </inertial>
        <visual>
            <geometry>
                <box size="0.03 0.03 0.03"/>
            </geometry>
            <material name="side_camera_color">
                <color rgba="0.20 0.75 0.35 1.0"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.03 0.03 0.03"/>
            </geometry>
        </collision>
    </link>

    <joint name="side_front_camera_joint" type="fixed">
        <parent link="world"/>
        <child link="side_front_camera_link"/>
        <origin xyz="0.00 -0.90 0.40" rpy="0 -0.15 1.57083"/>
    </joint>

    <gazebo reference="side_front_camera_link">
        <gravity>false</gravity>
        <sensor type="camera" name="side_front_camera_sensor">
            <always_on>true</always_on>
            <update_rate>30.0</update_rate>
            <camera>
                <horizontal_fov>2.00</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>15.0</far>
                </clip>
            </camera>
            <plugin name="side_front_camera_plugin" filename="libgazebo_ros_camera.so">
                <ros>
                    <namespace>/side_front_camera</namespace>
                    <remapping>image_raw:=image_raw</remapping>
                </ros>
                <camera_name>side_front_camera</camera_name>
                <frame_name>side_front_camera_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ros2_control definition -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <joint name="joint1">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint2">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint3">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint4">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint5">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint6">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hand_narrow_loop_joint">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
        <joint name="hand_wide_loop_joint">
            <command_interface name="position"/>
            <state_interface name="position">
                <param name="initial_value">0.0</param>
            </state_interface>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <!-- Load ros2_control plugin -->
    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
            <parameters>$(find arm620_config)/config/ros2_controllers_lerobot.yaml</parameters>
        </plugin>
    </gazebo>

</robot>
